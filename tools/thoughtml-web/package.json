{
  "name": "thoughtml-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Live editor and graph playground for ThoughtML.",
  "scripts": {
    "wasm": "wasm-pack build ../thoughtml-wasm --target web --out-dir ../thoughtml-web/src/wasm --out-name thoughtml_wasm --release",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.1.0",
    "@codemirror/commands": "^6.6.0",
    "@codemirror/language": "^6.10.0",
    "@codemirror/lint": "^6.8.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.30.0",
    "@lezer/highlight": "^1.2.0",
    "cytoscape": "^3.30.0",
    "cytoscape-dagre": "^2.5.0",
    "dagre": "^0.8.5"
  },
  "devDependencies": {
    "@types/cytoscape": "^3.21.0",
    "@types/dagre": "^0.7.52",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
